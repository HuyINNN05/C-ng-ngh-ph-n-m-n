<!DOCTYPE html>
<html>
    <%- include('../partials/header') %>

  <body>
    <nav class="navbar navbar-default no-margin">
      <div class="navbar-header fixed-brand">
        <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" id="menu-toggle">
          <span class="glyphicon glyphicon-th-large" style="margin-left: 5px" aria-hidden="true"></span>
        </button>
        <a class="navbar-brand" href="#"><i class="fa fa-a fa-4"></i>
          <%= userName %>
        </a>
      </div>

      <div class="collapse navbar-collapse" id="bs-example-navbar-collapse-1">
        <ul class="nav navbar-nav">
          <li class="active">
            <button class="navbar-toggle collapse in" data-toggle="collapse" id="menu-toggle-2">
              <span class="glyphicon glyphicon-th-large" aria-hidden="true"></span>
            </button>
          </li>
          <li class="navbar-brand">
            <form action="/logout" method="get">
              <button id="logout" type="submit" style="margin-top: -3px" class="btn btn-default">
                <i class="fa fa-user" aria-hidden="true"></i> Logout
              </button>
            </form>
          </li>
        </ul>
      </div>
    </nav>

    <div id="wrapper">
      <div id="sidebar-wrapper">
        <ul class="sidebar-nav nav-pills nav-stacked" id="menu">
          <li>
            <a href="#" id="menu3"><span class="fa-stack fa-lg pull-left"><i class="fa fa-users fa-stack-1x"></i></span>
              Employees</a>
            <ul class="nav-pills nav-stacked" style="list-style-type: none">
              <li>
                <a href="/admin/view-all-employees"><span class="fa-stack fa-lg pull-left"><i
                      class="fa fa-eye fa-stack-1x"></i></span>View Employees</a>
              </li>
              <li>
                <a href="/admin/add-employee"><span class="fa-stack fa-lg pull-left"><i
                      class="fa fa-plus fa-stack-1x"></i></span>Add Employees</a>
              </li>
            </ul>
          </li>
          <li class="active">
            <a href="/admin/salary-board"><span class="fa-stack fa-lg pull-left"><i
                  class="fa fa-money fa-stack-1x"></i></span>Salary Board</a>
          </li>
          <li>
            <a href="/admin/leave-applications"><span class="fa-stack fa-lg pull-left"><i
                  class="fa fa-envelope-square fa-stack-1x"></i></span>
              Leave Applications</a>
          </li>
          <li data-toggle="modal" data-target="#myModal">
            <a href="#">
              <span class="fa-stack fa-lg pull-left"><i class="fa fa-list-ol fa-stack-1x"></i></span>View Attendance</a>
          </li>
          <li data-toggle="modal" data-target="#myModal2">
            <a href="#"><span class="fa-stack fa-lg pull-left"><i class="fa fa-check-circle fa-stack-1x"></i></span>Mark
              Attendance</a>
          </li>
          <li>
            <a href="/admin/view-profile"><span class="fa-stack fa-lg pull-left"><i
                  class="fa fa-user fa-stack-1x"></i></span>View Profile</a>
          </li>
        </ul>
      </div>

      <div id="page-content-wrapper">
        <div class="container-fluid xyz">
          <div class="row">
            <div class="col-lg-12">
              <h1>Salary Board</h1>
              <form method="get" action="/admin/salary-board" class="form-inline" style="margin-bottom: 15px">
                <label for="month">Month:</label>
                <select name="month" id="month" class="form-control" style="margin: 0 8px">
                  <% for(let m=1; m<=12; m++){ %>
                    <option value="<%= m %>" <%= m===month ? 'selected' : '' %>><%= m %></option>
                  <% } %>
                </select>
                <label for="year">Year:</label>
                <input type="number" id="year" name="year" class="form-control" value="<%= year %>" min="2000" max="2100" style="margin: 0 8px" />
                <button type="submit" class="btn btn-default">View</button>
              </form>

              <div style="height: 600px; overflow: auto">
                <table id="example" class="display" cellspacing="0" style="width:100%">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Email</th>
                      <th>Base Salary</th>
                      <th>Bonus</th>
                      <th>Bonus Reason</th>
                      <th>Working Days</th>
                      <th>Approved Leave</th>
                      <th>Unauthorized Leave</th>
                      <th>Net Salary</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% payrollRows.forEach(function(row){ %>
                      <tr>
                        <td><%= row.user.name %></td>
                        <td><%= row.user.email %></td>
                        <td><%= Number(row.salaryRecord.salary || 0).toFixed(2) %></td>
                        <td><%= Number(row.salaryRecord.bonus || 0).toFixed(2) %></td>
                        <td><%= row.salaryRecord.reasonForBonus || 'N/A' %></td>
                        <td><%= row.workingDays %></td>
                        <td><%= row.approvedLeaveDays %></td>
                        <td><%= row.unauthorizedLeaveDays %></td>
                        <td><strong><%= row.netSalary %></strong></td>
                        <td>
                          <form method="post" action="/admin/salary-board/update/<%= row.user.id %>" class="form-inline">
                            <input type="number" class="form-control" name="salary" min="0" step="0.01" value="<%= Number(row.salaryRecord.salary || 0).toFixed(2) %>" style="width: 110px; margin-bottom: 6px" required>
                            <input type="number" class="form-control" name="bonus" min="0" step="0.01" value="<%= Number(row.salaryRecord.bonus || 0).toFixed(2) %>" style="width: 100px; margin-bottom: 6px" required>
                            <input type="text" class="form-control" name="reasonForBonus" value="<%= row.salaryRecord.reasonForBonus || 'N/A' %>" style="width: 160px; margin-bottom: 6px" required>
                            <input type="hidden" name="month" value="<%= month %>">
                            <input type="hidden" name="year" value="<%= year %>">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-default" style="margin-bottom: 6px">Save</button>
                          </form>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.3/jquery.js" charset="UTF-8"></script>
    <script src="http://maxcdn.bootstrapcdn.com/bootstrap/3.3.6/js/bootstrap.js" charset="UTF-8"></script>
    <script src="https://cdn.datatables.net/1.10.12/js/jquery.dataTables.min.js"></script>
    <script src="/javascripts/sidebar_menu.js"></script>
    <script>
      $(document).ready(function () {
        $('#example').dataTable({
          order: []
        });
      });
    </script>
  </body>

  <div id="myModal2" class="modal fade" role="dialog">
    <div class="modal-dialog">
      <form method="post" action="/admin/mark-attendance">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal">&times;</button>
            <h4 class="modal-title">Mark Attendance</h4>
          </div>
          <div class="modal-body">
            <p>Are you sure you want to mark attendance.</p>
          </div>
          <div class="modal-footer">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="reset" class="btn btn-default" data-dismiss="modal">No</button>
            <button type="submit" class="btn btn-default">Yes</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog">
      <div class="modal-content">
        <form method="post" action="/admin/view-attendance">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal">&times;</button>
            <h4 class="modal-title">Select Month/Year</h4>
          </div>
          <div class="modal-body">
            <div class="form-group">
              <label for="Month">Month:</label>
              <select class="form-control" id="attendance-month" name="month">
                <option value="1">January</option>
                <option value="2">February</option>
                <option value="3">March</option>
                <option value="4">April</option>
                <option value="5">May</option>
                <option value="6">June</option>
                <option value="7">July</option>
                <option value="8">August</option>
                <option value="9">September</option>
                <option value="10">October</option>
                <option value="11">November</option>
                <option value="12">December</option>
              </select>
            </div>
            <div class="form-group">
              <label for="attendance-year">Year:</label>
              <select class="form-control" id="attendance-year" name="year"></select>
            </div>
          </div>
          <div class="modal-footer">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="reset" class="btn btn-default" data-dismiss="modal">Close</button>
            <button type="submit" class="btn btn-default">View</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</html>
